# =========================================
# API 配置（环境相关）
# =========================================

# 视频 API 基础 URL（用于 server/convert.py 连接 API）
VIDEO_API_BASE_URL=your_video_api_base_url_here

# API 服务器监听地址和端口（用于 server/fast_api.py）
API_HOST=your_api_host_here
API_PORT=your_apy_port_here

# =========================================
# LLM 配置（隐私相关）
# =========================================

# LLM 提供商 (openai / 其他)
LLM_PROVIDER=openai

# OpenAI 模型名称
OPENAI_MODEL=gpt-4o-mini

# OpenAI API Key（必须填写）
OPENAI_API_KEY=your_openai_api_key_here

# =========================================
# 可选：其他 LLM 服务的 API Keys
# =========================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
